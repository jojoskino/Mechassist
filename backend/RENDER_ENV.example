# Copier ces variables dans Render > mechassist-api > Environment
# Supabase : Connect > Session pooler > URI (PAS "Direct connection")

APP_NAME=MechAssist
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:REMPLACER_AVEC_php_artisan_key_generate_show
APP_URL=https://mechassist-api.onrender.com

DB_CONNECTION=pgsql
DB_SSLMODE=require

# URI complète Supabase > Connect > Session pooler (user = postgres.[ref], PAS "postgres" seul)
DATABASE_URL=postgresql://postgres.ejyqsfqrhdydrrhyajww:VOTRE_MOT_DE_PASSE@aws-1-eu-north-1.pooler.supabase.com:5432/postgres

# NE PAS mettre DB_HOST=db.xxxxx.supabase.co sur Render (IPv6 → échec)

LOG_CHANNEL=stderr
LOG_LEVEL=warning
L5_SWAGGER_UI_ENABLED=false
