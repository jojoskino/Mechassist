APP_NAME=MechAssist
APP_ENV=local
# Obligatoire : php artisan key:generate — en production Render, coller la clé dans les variables d'environnement.
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL local (recommandé) : crée la base `mechassist` puis migrate — voir DEPLOY_POSTGRESQL.md
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=mechassist
DB_USERNAME=postgres
DB_PASSWORD=
DB_SSLMODE=prefer
# Supabase en local (connexion directe OK) :
# DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxxx.supabase.co:5432/postgres
#
# Supabase sur Render (OBLIGATOIRE : pooler, pas db.*.supabase.co — IPv6) :
# Supabase > Connect > Session pooler > URI
# DATABASE_URL=postgresql://postgres.[ref]:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
# DB_SSLMODE=require
# Ne pas définir DB_HOST en plus si DATABASE_URL est défini.

# Alternative sans PostgreSQL : commente le bloc ci-dessus et décommente SQLite (créer database/database.sqlite vide).
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

# Après `php artisan migrate --seed`, comptes démo :
# client@mechassist.local / MechAssist2026!
# mecanicien@mechassist.local / MechAssist2026!

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# URL publique du backend (photos /storage). Si vide, l’hôte de chaque requête API est utilisé.
# Exemple téléphone : http://192.168.1.42:8000
ASSET_URL=

# FCM HTTP legacy (clé serveur) : Firebase Console > Paramètres projet > Cloud Messaging > Clé serveur
# Sans cette clé, l’API fonctionne mais aucune notification push ne part du backend.
FCM_SERVER_KEY=

# Carte Google Maps (Flutter Web) : clé API avec Maps JavaScript API activée.
# Exposée via GET /api/client-config (clé publique navigateur, restreins-la par HTTP referrer).
GOOGLE_MAPS_WEB_API_KEY=

# Duplication optionnelle vers Cloud Firestore (désactivée par défaut). Tout le métier est en PostgreSQL.
# Mets à true seulement si tu veux doubler présence / demandes / chat vers Firestore (ex. temps réel).
FIRESTORE_SYNC_ENABLED=false
# Compte de service : Firebase Console > Paramètres du projet > Comptes de service > Générer une nouvelle clé privée (JSON).
# Place le fichier hors du dépôt Git et mets le chemin absolu ici. Rôle IAM recommandé : « Éditeur Cloud Datastore ».
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# Connexion Google : client OAuth « Application Web » (même ID que serverClientId côté Flutter).
GOOGLE_CLIENT_ID=
# Optionnel : client Android si l’id_token a cette audience (sinon laisser vide et utiliser serverClientId Web dans l’app).
GOOGLE_ANDROID_CLIENT_ID=

# Documentation API (L5-Swagger) : {APP_URL}/api/documentation — générer avec : php artisan l5-swagger:generate
# En production, laisser false pour ne pas régénérer la spec à chaque requête.
L5_SWAGGER_GENERATE_ALWAYS=false
# UI Swagger : true en local. En production, mets false pour renvoyer 404 sur /api/documentation.
L5_SWAGGER_UI_ENABLED=true

# Après déploiement : php artisan storage:link (photos des demandes sur le disque public).

# ---------------------------------------------------------------------------
# Production (Render Docker + Supabase) — voir DEPLOY_RENDER.md
# ---------------------------------------------------------------------------
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://your-service.onrender.com
# ASSET_URL=https://your-service.onrender.com
# LOG_CHANNEL=stderr
# LOG_LEVEL=warning
# DB_SSLMODE=require
# L5_SWAGGER_UI_ENABLED=false
# L5_SWAGGER_GENERATE_ALWAYS=false
# PORT=10000
# Health check : GET /api/health → {"status":"ok"}
# DB test     : GET /api/db-test → {"status":"DB OK"} or {"status":"DB FAIL","error":"..."}
