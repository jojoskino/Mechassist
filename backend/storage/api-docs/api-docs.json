                },
                "responses": {
                    "200": {
                        "description": "OK + token"
                    },
                    "401": {
                        "description": "Jeton Google invalide"
                    },
                    "503": {
                        "description": "Google non configuré"
                    }
                },
                "servers": [
                    {
                        "url": "/",
                        "description": "Serveur d’exécution (ex. http://127.0.0.1:8000)"
