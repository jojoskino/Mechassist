{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter (menu appareil)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/frontend",
      "program": "lib/main.dart"
    },
    {
      "name": "Web - Client (53100)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/frontend",
      "program": "lib/main.dart",
      "deviceId": "web-server",
      "args": [
        "--web-port=53100",
        "--web-hostname=localhost",
        "--dart-define=API_BASE_URL=http://127.0.0.1:8000"
      ]
    },
    {
      "name": "Web - Mecanicien (53101)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/frontend",
      "program": "lib/main.dart",
      "deviceId": "web-server",
      "args": [
        "--web-port=53101",
        "--web-hostname=localhost",
        "--dart-define=API_BASE_URL=http://127.0.0.1:8000"
      ]
    },
    {
      "name": "Android",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/frontend",
      "program": "lib/main.dart",
      "args": [
        "--dart-define=API_BASE_URL=http://10.0.2.2:8000"
      ]
    }
  ],
  "compounds": [
    {
      "name": "Client + Mecanicien (2 ports)",
      "configurations": ["Web - Client (53100)", "Web - Mecanicien (53101)"]
    }
  ]
}
