{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "MechAssist Web (local, 1 onglet)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/frontend",
      "program": "lib/main.dart",
      "deviceId": "web-server",
      "args": [
        "--web-port=53100",
        "--web-hostname=localhost",
        "--dart-define=API_BASE_URL=http://127.0.0.1:8000"
      ]
    },
    {
      "name": "MechAssist Android",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/frontend",
      "program": "lib/main.dart",
      "args": [
        "--dart-define=API_BASE_URL=http://10.0.2.2:8000"
      ]
    }
  ]
}
